# stratus-runtime example configuration.
# Copy to .env and fill in. NEVER commit real secrets.

# Server
PORT=8080
METRICS_PORT=9091
SHUTDOWN_TIMEOUT=30s

# GCP / Firestore (the runner-request queue backend)
GOOGLE_CLOUD_PROJECT=
FIRESTORE_DB=(default)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# Kubernetes
# KUBECONFIG=/path/to/kubeconfig   # leave unset for in-cluster config
RUNNER_NAMESPACE=arc-runners
GHCR_BASE=ghcr.io/your-org
GHCR_SECRET=ghcr-secret
SANDBOX_IMAGE=ghcr.io/your-org/sandbox-kata:latest

# Webhook (REQUIRED in production)
GITHUB_WEBHOOK_SECRET=
WEBHOOK_UPSTREAM_URL=http://localhost:8080/webhooks/github

# JIT controller
STRATUS_INSTALLATION_ID=
METRICS_PUSH_INTERVAL=30s
REAPER_INTERVAL=30s
MIN_SCHEDULED_AGE=2m
RETRY_BASE_INTERVAL=30s
RETRY_MAX_INTERVAL=5m
STARTUP_RECOVERY_THRESHOLD=2m

# Auth (optional)
STRATUS_AUTH_JWT_SECRET=
STRATUS_AUTH_JWT_ISSUER=stratus
STRATUS_AUTH_JWT_AUDIENCE=stratus-runtime

# Misc
STRATUS_VERSION=dev
# DEBUG=1
